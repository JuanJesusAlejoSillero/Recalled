# Flask
FLASK_ENV=production

# Generate each one with: python -c "import secrets; print(secrets.token_hex(32))"
# They must be different from each other
SECRET_KEY=<paste_generated_key_here>
JWT_SECRET_KEY=<paste_another_generated_key_here>

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YourSecurePassword123!

# Database
DATABASE_URL=sqlite:////app/data/reviews.db

# File uploads
UPLOAD_FOLDER=/app/uploads
# Max upload size (50 MB - supports multiple high-res phone photos)
MAX_CONTENT_LENGTH=52428800
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp

# CORS (comma-separated origins)
# Defaults assume the app is served behind HTTPS
CORS_ORIGINS=https://localhost

# Auth rate limits and shared storage
AUTH_LOGIN_RATE_LIMIT=5/minute
AUTH_2FA_RATE_LIMIT=10/minute
AUTH_REFRESH_RATE_LIMIT=30/minute
RATELIMIT_STORAGE_URI=redis://redis:6379/0

# Cookie auth hardening
# Defaults assume HTTPS. Change this manually if you run plain HTTP.
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAMESITE=Lax

# Port to expose the app on (default: 8090)
APP_PORT=8090

# Port for the dev stack (docker-compose.dev.yml), must differ from APP_PORT (default: 8091)
APP_DEV_PORT=8091

# Image tag for docker-compose.yml (default: latest)
# Use a specific version like 1.0.0 to pin, or latest for the newest build
IMAGE_TAG=latest

# Frontend
VITE_API_URL=/api/v1

# Optional features
# Enable the world map page showing place locations (true/false)
ENABLE_MAP=true
